{
  "name": "astro-theme-vitesse",
  "type": "module",
  "version": "1.1.1",
  "description": "A minimal, SEO-friendly portfolio and blog theme for Astro, supports Vue and UnoCSS.",
  "author": "rbxch",
  "license": "MIT",
  "keywords": [
    "astro",
    "blog",
    "starter"
  ],
  "engines": {
    "node": ">=v20.10.0 || >=22"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "bumpp"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.0.2",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/vue": "^5.0.2",
    "@unocss/reset": "^0.61.9",
    "astro": "^5.0.6",
    "nprogress": "^0.2.0",
    "unocss": "^0.65.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.27.3",
    "@eslint/js": "^9.17.0",
    "@iconify/json": "^2.2.283",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/lodash-es": "^4.17.12",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/parser": "^8.18.1",
    "@unocss/eslint-config": "^0.65.1",
    "@vueuse/core": "^10.11.1",
    "bumpp": "^9.9.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-format": "^0.1.3",
    "globals": "^15.13.0",
    "lint-staged": "^15.2.11",
    "lodash-es": "^4.17.21",
    "prettier": "3.4.2",
    "prettier-plugin-astro": "^0.13.0",
    "simple-git-hooks": "^2.11.1",
    "typescript-eslint": "^8.18.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  }
}
