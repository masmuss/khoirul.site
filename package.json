{
	"name": "personal-web",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev --host",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome lint .",
		"format": "bun run format:code && bun run format:imports",
		"format:code": "prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
		"format:imports": "biome check --formatter-enabled=false --write",
		"check": "astro check",
		"test:unit": "vitest",
		"test:unit:run": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/markdown-remark": "7.1.0",
		"@astrojs/mdx": "5.0.3",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.2",
		"@tailwindcss/vite": "^4.2.1",
		"astro": "6.1.7",
		"astro-mermaid": "^1.2.0",
		"mermaid": "^11.12.2",
		"rehype-external-links": "^3.0.0",
		"rehype-mermaid": "^3.0.0",
		"remark-directive": "^4.0.0",
		"remark-gfm": "^4.0.1",
		"satori-astro": "^0.3.3",
		"satori-html": "^0.3.2",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.1.2",
		"@iconify-json/carbon": "^1.2.15",
		"@iconify-json/logos": "^1.2.10",
		"@iconify-json/ri": "^1.2.7",
		"@iconify/json": "^2.2.423",
		"@iconify/tailwind4": "^1.2.0",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/typography": "^0.5.19",
		"@types/nprogress": "^0.2.3",
		"lefthook": "^2.0.13",
		"playwright": "^1.57.0",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-organize-attributes": "1.0.0",
		"prettier-plugin-organize-imports": "4.3.0",
		"prettier-plugin-packagejson": "3.0.2",
		"prettier-plugin-sort-json": "4.2.0",
		"prettier-plugin-tailwindcss": "0.7.3",
		"sharp": "^0.34.5",
		"vitest": "^4.1.5"
	}
}
