---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/card/Card.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardFooter from "@/components/ui/card/CardFooter.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import { cn } from "@/lib/utils/tailwind";

interface Props {
	href?: string;
	liveHref?: string;
	repoHref?: string;
	heading: string;
	subheading?: string;
	thumbnail?: string;
	class?: string;
}

const { href, liveHref, repoHref, heading, subheading, thumbnail, class: className } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/images/**/*.{jpeg,jpg,png,gif,webp,avif}",
);

const fallbackThumbnailPath = "/src/assets/images/coming-soon.png";
const thumbnailCandidates = thumbnail
	? [thumbnail, `/src/assets/images/projects/${thumbnail}`, `/src/assets/images/${thumbnail}`]
	: [];

const thumbnailPath =
	thumbnailCandidates.find((candidate) => Boolean(images[candidate])) ?? fallbackThumbnailPath;
const thumbnailImage = await images[thumbnailPath]();

const effectiveLiveHref = liveHref ?? (!repoHref ? href : undefined);
const effectiveRepoHref = repoHref;

const hasSingleAction =
	Number(Boolean(effectiveLiveHref)) + Number(Boolean(effectiveRepoHref)) === 1;
---

<Card
	class={cn(
		"mx-auto w-full max-w-sm pt-0 transition-all duration-300 hover:-translate-y-0.5 hover:ring-primary/40",
		className,
	)}
>
	<Image
		src={thumbnailImage.default}
		alt={`${heading} thumbnail`}
		class="aspect-video w-full object-cover"
		loading="lazy"
	/>
	<CardHeader class="flex flex-1 flex-col">
		<CardTitle class="text-base">{heading}</CardTitle>
		{subheading && <CardDescription class="line-clamp-2 text-xs">{subheading}</CardDescription>}
	</CardHeader>

	{
		(effectiveRepoHref || effectiveLiveHref) && (
			<CardFooter
				class={cn(
					"grid w-full gap-2 pt-3",
					hasSingleAction ? "grid-cols-1" : "grid-cols-2",
				)}
			>
				{effectiveRepoHref && (
					<Button
						as="a"
						href={effectiveRepoHref}
						target="_blank"
						rel="noopener noreferrer"
						variant={hasSingleAction ? "default" : "secondary"}
						size="sm"
						class="w-full"
					>
						<span slot="icon-before" class="iconify ri--github-line" aria-hidden="true" />
						Repo
					</Button>
				)}

				{effectiveLiveHref && (
					<Button
						as="a"
						href={effectiveLiveHref}
						target="_blank"
						rel="noopener noreferrer"
						variant="default"
						size="sm"
						class="w-full"
					>
						<span slot="icon-before" class="iconify ri--external-link-line" aria-hidden="true" />
						Live
					</Button>
				)}
			</CardFooter>
		)
	}
</Card>
