---
import type { CollectionEntry } from "astro:content";
import PostMetadata from "@/components/common/PostMetadata.astro";
import Card from "@/components/ui/card/Card.astro";
import { getPostUrl } from "@/lib/utils";

type Props = {
	post: CollectionEntry<"post">;
};

const { post } = Astro.props;
---

<li>
	<Card
		as="a"
		href={getPostUrl(post)}
		reload
		class="group -mx-3 overflow-visible rounded-none border-0 bg-transparent px-3 py-3 text-base opacity-90 ring-0 transition-opacity hover:opacity-100"
	>
		<div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-4">
			<span
				class="group-hover:text-foreground flex-1 font-medium transition-colors sm:line-clamp-1"
			>
				{post.data.title}
			</span>
			<span class="text-muted-foreground shrink-0">
				<PostMetadata post={post} />
			</span>
		</div>
	</Card>
</li>
