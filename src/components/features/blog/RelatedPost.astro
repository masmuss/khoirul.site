---
import { getReadTimeCount } from "@/lib/contents";
import { getFormattedDate } from "@/lib/utils";
import { getPostUrl } from "@/lib/utils/post-route";
import type { CollectionPosts } from "@/types";

interface Props {
	relatedPosts: CollectionPosts[];
}

const { relatedPosts } = Astro.props;
---

{
	relatedPosts.length > 0 && (
		<div class="border-border/40 mt-12 flex flex-col gap-y-4 border-t pt-8">
			<h2 class="text-muted-foreground mb-2 text-sm font-medium tracking-wider uppercase">
				Related Posts
			</h2>
			<div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
				{relatedPosts.map((post) => (
					<a
						href={getPostUrl(post)}
						class="group border-border/50 bg-secondary/10 hover:bg-secondary/30 hover:border-border flex flex-col gap-2 rounded-xl border p-5 transition-all duration-300"
						data-astro-reload
					>
						<span class="text-foreground group-hover:text-primary line-clamp-2 leading-snug font-medium transition-colors">
							{post.data.title}
						</span>
						<span class="text-muted-foreground mt-auto pt-2 text-xs">
							{getFormattedDate(post.data.date)}
							{post.body && ` · ${getReadTimeCount(post.body)} min(s) read`}
						</span>
					</a>
				))}
			</div>
		</div>
	)
}
