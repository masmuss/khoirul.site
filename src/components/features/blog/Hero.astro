---
import type { CollectionEntry } from "astro:content";
import PostMetadata from "@/components/common/PostMetadata.astro";
import siteConfig from "@/config/site-config";
import PostImage from "./PostImage.astro";

interface Props {
	content: CollectionEntry<"post">;
	coverImageResolved: {
		src: string;
		alt: string;
	};
}

const { content, coverImageResolved }: Props = Astro.props;

const dateTimeOptions: Intl.DateTimeFormatOptions = {
	month: "long",
};
---

<header class="flex flex-col items-center justify-center gap-4">
	<div class="flex flex-col items-center gap-3">
		<div class="text-muted-foreground flex items-center gap-2 text-sm">
			<span>{siteConfig.author}</span>
			<span>·</span>
			<PostMetadata post={content} dateTimeOptions={dateTimeOptions} readTimeStyle="long" />
		</div>
		<h1 class="text-center text-2xl leading-tight font-semibold md:text-3xl">
			{content.data.title}
		</h1>
		{
			content.data.tags.length > 0 && (
				<div class="flex flex-wrap items-center justify-center gap-2">
					{content.data.tags.map((tag) => (
						<a
							href={`/tags/${tag}/`}
							class="text-muted-foreground hover:text-foreground px-3 py-1 text-xs transition-colors"
						>
							# {tag}
						</a>
					))}
				</div>
			)
		}
	</div>
</header>

<>
	{
		content.data.coverImage && (
			<PostImage src={coverImageResolved.src} alt={coverImageResolved.alt || content.data.title} />
		)
	}
</>
