---
import Card from "@/components/ui/card/Card.astro";
import CardContent from "@/components/ui/card/CardContent.astro";
import CardDescription from "@/components/ui/card/CardDescription.astro";
import CardHeader from "@/components/ui/card/CardHeader.astro";
import CardTitle from "@/components/ui/card/CardTitle.astro";
import Section from "@/components/ui/Section.astro";
import { getExperienceGroups } from "@/lib/contents/experiences";
import type { Experience } from "@/types";

interface Props {
	experiences: Experience[];
}

const { experiences }: Props = Astro.props;

const groupedByCompany = getExperienceGroups(experiences);
---

<Section title="Experience">
	<div class="relative pl-6 md:pl-8">
		<div class="bg-border absolute top-0 bottom-0 left-0 w-px" aria-hidden="true"></div>

		{
			groupedByCompany.map((organization) => (
				<article class="relative pb-8 last:pb-0">
					<div
						class="bg-primary absolute top-2 -left-7 h-2.5 w-2.5 rounded-full md:-left-9"
						aria-hidden="true"
					/>

					<Card class="p-0 ring-0">
						<CardHeader class="pb-0">
							<div class="flex flex-wrap items-center gap-x-2 gap-y-1">
								<CardTitle as="h3" class="leading-tight">
									{organization.company}
								</CardTitle>
								{organization.kind === "campus" && organization.umbrellaOrg && (
									<span class="text-muted-foreground rounded-full border px-2 py-0.5 text-[11px]">
										Campus Experience · {organization.umbrellaOrg}
									</span>
								)}
							</div>
							<CardDescription class="text-sm leading-relaxed">
								{organization.location ?? "Remote"}
								<span aria-hidden="true"> · </span>
								{organization.positions.length} role{organization.positions.length > 1 ? "s" : ""}
							</CardDescription>
						</CardHeader>

						<CardContent class="pt-3">
							<div class="space-y-3">
								{organization.positions.map((position) => (
									<div class="border-border/40 border-l pl-4">
										<div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
											<div class="min-w-0">
												<h4 class="text-base leading-tight font-medium">{position.title}</h4>
												<p class="text-muted-foreground mt-2 text-sm leading-relaxed">
													{position.summary ?? position.highlights[0]}
												</p>
											</div>
											<span class="text-muted-foreground inline-flex w-fit shrink-0 text-xs font-medium">
												{position.period}
											</span>
										</div>

										{position.skills && position.skills.length > 0 && (
											<p class="text-muted-foreground mt-2 text-xs leading-relaxed">
												Tech: {position.skills.join(" · ")}
											</p>
										)}

										{position.highlights.length > 0 && (
											<details class="mt-2">
												<summary class="text-muted-foreground cursor-pointer text-xs">
													Show details
												</summary>
												<ul class="text-muted-foreground mt-2 ml-4 list-disc space-y-1.5 text-sm leading-relaxed">
													{position.highlights.map((highlight) => (
														<li>{highlight}</li>
													))}
												</ul>
											</details>
										)}
									</div>
								))}
							</div>
						</CardContent>
					</Card>
				</article>
			))
		}
	</div>
</Section>
