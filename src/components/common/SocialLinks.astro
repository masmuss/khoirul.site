---
import Button from "@/components/ui/Button.astro";
import siteConfig from "@/config/site-config";
import { cn } from "@/lib/utils";

interface Props {
	variant?: "icon" | "button";
	showEmail?: boolean;
	class?: string;
}

const { variant = "icon", showEmail = false, class: className } = Astro.props;
---

<div
	class={cn(
		"flex items-center",
		variant === "button" ? "flex-wrap gap-3" : "gap-4",
		className
	)}
>
	{
		showEmail && (
			<Button
				as="a"
				href={`mailto:${siteConfig.email}`}
				target="_blank"
				rel="noopener noreferrer"
				variant={variant === "button" ? "outline" : "ghost"}
				size={variant === "button" ? "default" : "icon-sm"}
				class={cn(
					"text-muted-foreground hover:text-foreground",
					variant === "button" && "gap-x-2"
				)}
				aria-label="Email"
				title={variant === "button" ? "Email" : undefined}
			>
				<span
					slot="icon-before"
					class={cn("iconify ri--mail-line", variant === "icon" && "text-xl")}
				/>
				{variant === "icon" && <span class="sr-only">Email</span>}
			</Button>
		)
	}
	{
		siteConfig.socialLinks.map((link) => (
			<Button
				as="a"
				href={link.href}
				target="_blank"
				rel="noopener noreferrer"
				variant={variant === "button" ? "outline" : "ghost"}
				size={variant === "button" ? "default" : "icon-sm"}
				class={cn(
					"text-muted-foreground hover:text-foreground",
					variant === "button" && "gap-x-2"
				)}
				aria-label={link.text}
				title={variant === "button" ? link.text : undefined}
			>
				<span
					slot="icon-before"
					class={cn("iconify", link.icon, variant === "icon" && "text-xl")}
				/>
				{variant === "icon" && <span class="sr-only">{link.text}</span>}
			</Button>
		))
	}
</div>
