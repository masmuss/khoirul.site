---
import JSONLD from "@/components/layout/JSONLD.astro";
import siteConfig from "@/config/site-config";

interface Props {
	title?: string;
	titleTemplate?: string;
	description?: string;
	ogType?: "website" | "article";
	ogImage?: string;
	ogImageAlt?: string;
	ogImageWidth?: number;
	ogImageHeight?: number;
	siteName?: string;
	twitter?: {
		site?: string;
		creator?: string;
		card?: "summary" | "summary_large_image";
	};
	article?: {
		publishedTime?: Date;
		modifiedTime?: Date;
		author?: string;
		tags?: string[];
	};
	extraLinks?: Array<{
		title?: string;
		rel: string;
		href: string;
		type?: string;
		media?: string;
		sizes?: string;
	}>;
}

const {
	title: rawTitle,
	titleTemplate = siteConfig.title,
	description: rawDescription,
	ogType = "website",
	ogImage,
	ogImageAlt,
	ogImageWidth,
	ogImageHeight,
	siteName = siteConfig.title,
	twitter = { card: "summary_large_image" },
	article,
	extraLinks = []
} = Astro.props;

// Normalization Constants (Retained from original BaseHead)
const titleMinLength = 30;
const titleMaxLength = 60;
const descriptionMinLength = 120;
const descriptionMaxLength = 160;

function truncateByWordBoundary(text: string, maxLength: number) {
	if (text.length <= maxLength) return text;
	const sliced = text.slice(0, maxLength + 1);
	const cutIndex = Math.max(
		sliced.lastIndexOf(" "),
		sliced.lastIndexOf("-"),
		sliced.lastIndexOf("|")
	);
	const safeText = (
		cutIndex > Math.floor(maxLength * 0.7)
			? sliced.slice(0, cutIndex)
			: text.slice(0, maxLength)
	).trim();
	return `${safeText}...`;
}

function normalizeTitle(raw: string | undefined, type: typeof ogType) {
	if (!raw) return siteConfig.title;

	let normalized = raw;
	const suffix =
		type === "article" ? " | Articles by Khoirul" : ` | ${titleTemplate}`;

	if (normalized.length < titleMinLength) {
		normalized = `${normalized}${suffix}`;
	}

	if (normalized.length > titleMaxLength) {
		normalized = truncateByWordBoundary(normalized, titleMaxLength - 3);
	}

	return normalized;
}

function normalizeDescription(raw: string | undefined, type: typeof ogType) {
	const fallbackDescription =
		type === "article"
			? "Read this article on pictogrammmer for practical lessons, context, and related insights from Khoirul Fattah."
			: siteConfig.description;

	let normalized = (raw || "").trim() || fallbackDescription;

	if (normalized.length < descriptionMinLength) {
		const suffix =
			type === "article"
				? " Read the full article on pictogrammmer for complete context and practical takeaways."
				: " Explore more writing and projects on pictogrammmer for deeper context and practical resources.";
		normalized = `${normalized}${suffix}`;
	}

	if (normalized.length > descriptionMaxLength) {
		normalized = truncateByWordBoundary(normalized, descriptionMaxLength - 3);
	}

	return normalized;
}

const title = normalizeTitle(rawTitle, ogType);
const description = normalizeDescription(rawDescription, ogType);

// Canonical URL logic
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
function formatCanonicalURL(url: URL) {
	const normalizedUrl = new URL(url.toString());
	normalizedUrl.hash = "";
	const normalizedPath =
		normalizedUrl.pathname === "/"
			? "/"
			: normalizedUrl.pathname.replace(/\/+$/, "");
	return `${normalizedUrl.origin}${normalizedPath}${normalizedUrl.search}`;
}
const formattedCanonical = formatCanonicalURL(canonicalURL);

const resolvedOgImage = ogImage
	? new URL(ogImage, Astro.site).toString()
	: new URL(siteConfig.image.src, Astro.site).toString();

const resolvedOgImageAlt = ogImageAlt || siteConfig.image.alt;
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<link rel="canonical" href={formattedCanonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={formattedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
{
	resolvedOgImageAlt && (
		<meta property="og:image:alt" content={resolvedOgImageAlt} />
	)
}
{siteName && <meta property="og:site_name" content={siteName} />}
{
	ogImageWidth && (
		<meta property="og:image:width" content={ogImageWidth.toString()} />
	)
}
{
	ogImageHeight && (
		<meta property="og:image:height" content={ogImageHeight.toString()} />
	)
}

{
	ogType === "article" && article && (
		<>
			{article.publishedTime && (
				<meta
					property="article:published_time"
					content={article.publishedTime.toISOString()}
				/>
			)}
			{article.modifiedTime && (
				<meta
					property="article:modified_time"
					content={article.modifiedTime.toISOString()}
				/>
			)}
			{article.author && (
				<meta property="article:author" content={article.author} />
			)}
			{article.tags?.map((tag) => (
				<meta property="article:tag" content={tag} />
			))}
		</>
	)
}

<!-- Twitter -->
<meta property="twitter:card" content={twitter.card || "summary_large_image"} />
<meta property="twitter:url" content={formattedCanonical} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={resolvedOgImage} />
{
	resolvedOgImageAlt && (
		<meta name="twitter:image:alt" content={resolvedOgImageAlt} />
	)
}
{twitter.site && <meta name="twitter:site" content={twitter.site} />}
{twitter.creator && <meta name="twitter:creator" content={twitter.creator} />}

<!-- JSON-LD -->
<JSONLD
	title={title}
	description={description}
	image={resolvedOgImage}
	date={article?.publishedTime}
	updatedDate={article?.modifiedTime}
	type={ogType}
/>

<!-- Extra Links -->
{
	extraLinks.map((link) => (
		<link
			title={link.title}
			rel={link.rel}
			href={link.href}
			type={link.type}
			media={link.media}
			sizes={link.sizes}
		/>
	))
}
