---
import { cn } from "@/lib/utils";

interface Tool {
	name: string;
	description: string;
}

interface Props {
	showDescription?: boolean;
	class?: string;
	title: string;
	tools: Tool[];
}

const { showDescription, class: className, title, tools, ...props }: Props = Astro.props;
---

<section
	class={cn("grid grid-cols-1 gap-y-4 py-3 md:py-8 first:pt-0 md:grid-cols-4 md:gap-x-12")}
	{...props}
>
	<h2 class="text-foreground/80 text-sm font-semibold tracking-wider uppercase md:col-span-1">
		{title}
	</h2>
	<div class="md:col-span-3">
		<ul class={cn(`grid grid-cols-1 gap-x-2 gap-y-2 sm:grid-cols-2`, className)}>
			{
				tools.map((tool) => (
					<li class="flex flex-col rounded-xl px-2 py-2 md:mx-3 md:px-3 md:py-3">
						<div class="flex flex-col">
							<h3 class="text-foreground text-sm font-medium">{tool.name}</h3>
							{showDescription && (
								<p class="text-muted-foreground mt-0.5 text-xs leading-relaxed">
									{tool.description}
								</p>
							)}
						</div>
					</li>
				))
			}
		</ul>
	</div>
</section>
