---
import { cn } from "@/lib/utils";

type Props = {
	as?: keyof HTMLElementTagNameMap;
	class?: string;
	href?: string;
	size?: "default" | "sm";
	reload?: boolean;
	[key: string]: unknown;
};

const {
	as: Tag = "div",
	class: className,
	href,
	size = "default",
	reload = false,
	...attrs
}: Props = Astro.props;
const isAnchor = Tag === "a";
---

{
	isAnchor ? (
		<a
			{...attrs}
			href={href}
			data-astro-reload={reload ? true : undefined}
			data-slot="card"
			data-size={size}
			class={cn(
				"group/card bg-card text-card-foreground ring-foreground/10 flex flex-col gap-4 overflow-hidden rounded-xl py-4 text-sm ring-1 has-data-[slot=card-footer]:pb-0 has-[>img:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl",
				className
			)}
		>
			<slot />
		</a>
	) : (
		<Tag
			{...attrs}
			data-slot="card"
			data-size={size}
			class={cn(
				"group/card bg-card text-card-foreground ring-foreground/10 flex flex-col gap-4 overflow-hidden rounded-xl py-4 text-sm ring-1 has-data-[slot=card-footer]:pb-0 has-[>img:first-child]:pt-0 data-[size=sm]:gap-3 data-[size=sm]:py-3 data-[size=sm]:has-data-[slot=card-footer]:pb-0 *:[img:first-child]:rounded-t-xl *:[img:last-child]:rounded-b-xl",
				className
			)}
		>
			<slot />
		</Tag>
	)
}
