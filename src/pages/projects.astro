---
import ProjectCard from "@/components/features/projects/ProjectCard.astro";
import PageHeader from "@/components/ui/PageHeader.astro";
import Section from "@/components/ui/Section.astro";
import PageLayout from "@/layouts/BaseLayout.astro";
import { projectData } from "@/lib/constants/projects";
---

<PageLayout
	title="Projects in Web and Backend Development"
	description="Browse selected projects built by Khoirul Fattah, including web applications, backend services, and technical experiments focused on real-world problem solving."
	image={{ src: "/og/projects.png", alt: "Projects - pictogrammmer" }}
	pageType="website"
>
	<div class="flex w-full flex-col gap-y-10">
		<PageHeader
			title="Projects"
			description="A collection of projects I've worked on, from web applications to experiments."
			as="h1"
			class="mb-6"
		/>

		{
			projectData.map((category, index) => (
				<Section
					title={category.title}
					titleAs="h2"
					titleSize="base"
					titleWeight="medium"
					class="gap-y-4"
					transitionDelay={index * 150}
				>
					<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3">
						{category.projects.map((project) => (
							<ProjectCard
								href={project.href}
								liveHref={project.liveHref}
								repoHref={project.repoHref}
								heading={project.text}
								subheading={project.description}
								thumbnail={project.thumbnail}
								class="w-full"
							/>
						))}
					</div>
				</Section>
			))
		}
	</div>
</PageLayout>
