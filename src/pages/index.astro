---
import About from "@/components/features/home/About.astro";
import Hero from "@/components/features/home/Hero.astro";
import Posts from "@/components/features/home/Posts.astro";
import PageLayout from "@/layouts/BaseLayout.astro";
import { getAllPosts } from "@/lib/utils";

const MAX_POSTS = 5;
const allPosts = await getAllPosts(MAX_POSTS);
---

<PageLayout
	title="Home"
	description="Welcome to my personal website. Here you can find information about me, my projects, and my experiences."
	pageType="website"
>
	<div class="flex w-full flex-col gap-y-12">
		<Hero />
		<About />
		<Posts posts={allPosts} />
	</div>
</PageLayout>
