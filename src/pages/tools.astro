---
import ToolSection from "@/components/features/tools/ToolSection.astro";
import PageLayout from "@/layouts/BaseLayout.astro";

import TOOLS from "@/lib/constants/tools";
---

<PageLayout
	title="Daily Tools for Development and Creativity"
	description="Explore the software and hardware I use every day for coding, writing, and creative work, including practical tools that improve workflow and focus."
	image={{ src: "/og/tools.png", alt: "Tools - pictogrammmer" }}
	pageType="website"
>
	<div class="flex w-full flex-col gap-y-10">
		<div>
			<h1 class="mb-2 text-2xl font-semibold">Tools</h1>
			<p class="text-muted-foreground">Software and hardware I use daily.</p>
		</div>

		{TOOLS.map((tool) => <ToolSection showDescription title={tool.title} tools={tool.tools} />)}
	</div>
</PageLayout>
