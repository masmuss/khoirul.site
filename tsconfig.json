{
	"extends": "astro/tsconfigs/base",
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.astro",
		"tests/**/*.ts",
		".astro/types.d.ts",
		"env.d.ts"
	],
	"exclude": ["dist", "node_modules", "playwright-report", "test-results"],
	"compilerOptions": {
		"jsx": "preserve",
		"paths": {
			"@/*": ["./src/*"]
		},
		"strictNullChecks": false
	}
}
